rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function treeDoc(treeId) {
      return firestore.get(/databases/(default)/documents/trees/$(treeId));
    }

    function isTreeMember(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.memberIds;
    }

    function isTreeEditor(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.editorIds;
    }

    // Users can only read/write their own folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /treePhotos/{treeId}/{personId}/{allPaths=**} {
      allow read: if isTreeMember(treeId);
      allow write: if isTreeEditor(treeId);
    }
  }
}
