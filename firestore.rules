rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function treeDoc(treeId) {
      return get(/databases/$(database)/documents/trees/$(treeId));
    }

    function isTreeOwner(treeId) {
      return signedIn() && treeDoc(treeId).data.ownerId == request.auth.uid;
    }

    function isTreeMember(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.memberIds;
    }

    function isTreeEditor(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.editorIds;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /trees/{treeId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.editorIds;
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow update: if isTreeOwner(treeId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name is string
        && request.resource.data.memberIds is list
        && request.resource.data.editorIds is list
        && request.resource.data.collaborators is list;
      allow delete: if isTreeOwner(treeId);
    }

    match /persons/{personId} {
      allow create: if signedIn()
        && request.resource.data.treeId is string
        && request.resource.data.firstName is string
        && isTreeEditor(request.resource.data.treeId);
      allow read: if isTreeMember(resource.data.treeId);
      allow update: if isTreeEditor(resource.data.treeId)
        && request.resource.data.treeId == resource.data.treeId
        && request.resource.data.firstName is string;
      allow delete: if isTreeEditor(resource.data.treeId);
    }

    match /relationships/{relationshipId} {
      allow create: if signedIn()
        && request.resource.data.treeId is string
        && request.resource.data.fromPersonId is string
        && request.resource.data.toPersonId is string
        && request.resource.data.type in ['parent-child', 'spouse']
        && isTreeEditor(request.resource.data.treeId);
      allow read: if isTreeMember(resource.data.treeId);
      allow delete: if isTreeEditor(resource.data.treeId);
      allow update: if false;
    }
  }
}
