rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function treeDoc(treeId) {
      return get(/databases/$(database)/documents/trees/$(treeId));
    }

    function isTreeOwner(treeId) {
      return signedIn() && treeDoc(treeId).data.ownerId == request.auth.uid;
    }

    function isTreeMember(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.memberIds;
    }

    function isTreeEditor(treeId) {
      return signedIn() && request.auth.uid in treeDoc(treeId).data.editorIds;
    }

    function isOwnPersonAssignmentUpdate(treeId) {
      return signedIn()
        && isTreeMember(treeId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['personAssignments', 'updatedAt'])
        && request.resource.data.personAssignments is map
        && (
          !(resource.data.personAssignments is map)
          || request.resource.data.personAssignments.diff(resource.data.personAssignments).affectedKeys().hasOnly([request.auth.uid])
        )
        && (
          !(resource.data.personAssignments is map)
          || !(request.auth.uid in resource.data.personAssignments)
          || !(request.auth.uid in request.resource.data.personAssignments)
          || request.resource.data.personAssignments[request.auth.uid] == resource.data.personAssignments[request.auth.uid]
        )
        && (
          !(request.auth.uid in request.resource.data.personAssignments)
          || (
            request.resource.data.personAssignments[request.auth.uid] is string
            && exists(/databases/$(database)/documents/persons/$(request.resource.data.personAssignments[request.auth.uid]))
            && get(/databases/$(database)/documents/persons/$(request.resource.data.personAssignments[request.auth.uid])).data.treeId == treeId
          )
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /trees/{treeId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.editorIds
        && request.resource.data.personAssignments is map
        && (!('approvalWindowHours' in request.resource.data) || request.resource.data.approvalWindowHours is number);
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow update: if (
          isTreeOwner(treeId)
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.name is string
          && request.resource.data.memberIds is list
          && request.resource.data.editorIds is list
          && request.resource.data.collaborators is list
          && (!('approvalWindowHours' in request.resource.data) || request.resource.data.approvalWindowHours is number)
        )
        || isOwnPersonAssignmentUpdate(treeId);
      allow delete: if isTreeOwner(treeId);
    }

    match /approvalRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.treeId is string
        && isTreeMember(request.resource.data.treeId)
        && request.resource.data.requestedByUserId == request.auth.uid;
      allow read: if isTreeMember(resource.data.treeId);
      allow update: if isTreeMember(resource.data.treeId);
      allow delete: if isTreeOwner(resource.data.treeId);
    }

    match /persons/{personId} {
      allow create: if signedIn()
        && request.resource.data.treeId is string
        && request.resource.data.firstName is string
        && isTreeEditor(request.resource.data.treeId);
      allow read: if isTreeMember(resource.data.treeId);
      allow update: if isTreeEditor(resource.data.treeId)
        && request.resource.data.treeId == resource.data.treeId
        && request.resource.data.firstName is string;
      allow delete: if isTreeEditor(resource.data.treeId);
    }

    match /relationships/{relationshipId} {
      allow create: if signedIn()
        && request.resource.data.treeId is string
        && request.resource.data.fromPersonId is string
        && request.resource.data.toPersonId is string
        && request.resource.data.type in ['parent-child', 'spouse']
        && isTreeEditor(request.resource.data.treeId);
      allow read: if isTreeMember(resource.data.treeId);
      allow delete: if isTreeEditor(resource.data.treeId);
      allow update: if false;
    }
  }
}
